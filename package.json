		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"class-variance-authority": "^0.7.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.7.0",
		"mode-watcher": "^1.1.0",
